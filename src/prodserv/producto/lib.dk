        return lib.get_data(db, sql, pk)
    }
    function lib.get_data(&db, sql, pk)
    {
        new prm { @"pk": pk }
        ref rec = dbr.rec(db, sql, prm)
        return  ifnull(rec, record.create())
    }
    function filter_forma_comision(&formas, tipo)
    {
        ref list = list.create()
        for i = 0; i < list.count(formas)
        {
            ref forma = list.obj(formas, i)
            id_forma = @@(forma, '$id')
            
            if tipo == 0 && id_forma == '0' {
                do list.add(list, forma)
            }
            else if  tipo == 1 && (id_forma == '1' || id_forma == '2') {
                do list.add(list, forma)
            }
            else if tipo == 2 && (id_forma == '1' || id_forma == '2' || id_forma == '3') {
                do list.add(list, forma)
            }
        }
        return list
    }

    function set_ml_images(&images)
    {
        ref list = list.create()
        if not(isnull(images)) && list.count(images) > 0
        {
            for i = 0; i < list.count(images)
            {
                ref img = list.obj(images,i)
                url = @@(img,"src")
                mini = @@(img,"src")
                
                ref vars = ifnull(@@(img,"&variations"), list.create())
                ref min_var = get_variation_with_min_value(vars,"size")
                
                new ml_img
                {
                    @"id": @@(img,"$id")
                    @"url": url
                    @"mini": field.dstr(min_var, "src", mini)
                }
                do list.add(list, ml_img)
            }
        }

        return list
    }
    function get_variation_with_min_value(&lst,field)
    {
        ref variation = record.create()
        
        for i = 0; i < list.count(lst)
        {
            ref obj = list.obj(lst,i)
            if i == 0 { ref variation = obj }
            if @@(obj,"#"+field) < @@(variation, "#"+field){
                ref variation = obj
            }
        }

        return variation
    }
}