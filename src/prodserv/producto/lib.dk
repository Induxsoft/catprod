    function lib.get_divisa(&db, pk)
    {
        sql = "SELECT sys_pk, codigo, descripcion FROM divisa WHERE sys_pk=@pk LIMIT 1;"
        return lib.get_data(db, sql, pk)
    }
    function lib.get_linea(&db, pk)
    {
        sql = "SELECT sys_pk, codigo, descripcion FROM linea WHERE sys_pk=@pk LIMIT 1;"
        return lib.get_data(db, sql, pk)
    }
    function lib.get_departamento(&db, pk)
