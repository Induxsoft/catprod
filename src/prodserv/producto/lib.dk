#include "dkli.dkh"
#!
module "lib"
{
    function lib.def_clases_producto(&datatable, value)
    {
        new def
        {
            @"datatable*": datatable
            member "attributes"
            {
                @"name": "iclase"
                @"class": "induxsoft-form-select"
                @"required": "true"
            }
            @"text_field": "const"
            @"value_field": "id"
            @"selected": value
        }
        return def
    }
    function lib.def_tipo_comision(&datatable, value)
    {
        new def
        {
            @"datatable*": datatable
            member "attributes"
            {
                @"name": "tipocomision"
                @"class": "induxsoft-form-select"
                @"required": "true"
            }
            @"text_field": "const"
            @"value_field": "id"
            @"selected": value
        }
        return def
    }
    function lib.def_forma_comision(&datatable, value)
    {
        new def
        {
            @"datatable*": datatable
            member "attributes"
            {
                @"name": "formacomision"
                @"class": "induxsoft-form-select"
                @"required": "true"
            }
            @"text_field": "const"
            @"value_field": "id"
            @"selected": value
        }
        return def
    }
    function lib.def_tipos_producto(&datatable, value)
    {
        new def
        {
            @"datatable*": datatable
            member "attributes"
            {
                @"name": "itipo"
                @"class": "induxsoft-form-select"
                @"required": "true"
            }
            @"text_field": "const"
            @"value_field": "id"
            @"selected": value
        }
        return def
    }
