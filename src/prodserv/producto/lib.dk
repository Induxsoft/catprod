module "lib"
{
    function lib.def_clases_producto(&datatable, value)
    {
        new def
        {
            @"datatable*": datatable
            member "attributes"
            {
                @"name": "iclase"
                @"class": "induxsoft-form-select"
                @"required": "true"
            }
            @"text_field": "const"
            @"value_field": "id"
            @"selected": value
        }
        return def
    }
