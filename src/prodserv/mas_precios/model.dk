#include "dkli.dkh"
#!
module "Más precios"
{
    @table_name = "producto"

    function masprecios_update(&db,&params,&data)
    {
        exit = @@(data,"exit")

        if not(exit == "") {
            @url_redir = url_dcode(exit)
        } else {
            @url_redir = "/!/prodserv/productos/"
        }

        do field.remove(data,"exit")

        ref res = entity.update(db,params,data)
        return res
    }
    
    point @update to masprecios_update
}